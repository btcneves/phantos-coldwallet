[Unit]
Description=PhantOS ColdWallet Kiosk
After=graphical.target
Wants=graphical.target

[Service]
Type=simple
User=phantos
Environment=QT_QPA_PLATFORM=xcb
WorkingDirectory=/opt/phantos
ExecStart=/opt/phantos/.venv/bin/python -m app.main --kiosk
Restart=on-failure
RestartSec=2
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/tmp /run/user

[Install]
WantedBy=graphical.target

